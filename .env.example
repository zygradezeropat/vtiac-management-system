# Copy to .env and adjust — this system uses PostgreSQL.
# Export these in your shell (or use a loader) before migrate/runserver.

POSTGRES_DB=vtiac
POSTGRES_USER=vtiac
POSTGRES_PASSWORD=vtiac
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Django superuser (optional, for: python manage.py createsuperuser)
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me
